# TestCraft API Configuration

# Server
PORT=3000
CORS_ORIGIN=*
LOG_LEVEL=info
NODE_ENV=development

# YugabyteDB (PostgreSQL compatible with vector support)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=testcraft
DB_USER=yugabyte           # REQUIRED in production
DB_PASSWORD=yugabyte       # REQUIRED in production - change this!
DB_SSL=false
DB_POOL_SIZE=10

# Kubernetes
K8S_NAMESPACE=testcraft-runners
K8S_IN_CLUSTER=false
# KUBECONFIG=/path/to/kubeconfig  # Optional, uses default if not set

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Optional

# AI Configuration
AI_API_KEY=  # Anthropic or OpenAI API key
# AI_BASE_URL=https://api.anthropic.com/v1  # Default for Anthropic
AI_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# Execution
DEFAULT_TIMEOUT=60
MAX_TIMEOUT=300
MAX_CONCURRENT=10

# Rate Limiting
AI_RATE_LIMIT_MAX=100           # Max AI requests per window
AI_RATE_LIMIT_WINDOW_MS=60000   # Window in milliseconds (1 minute)
GLOBAL_RATE_LIMIT_MAX=1000      # Max total requests per window
GLOBAL_RATE_LIMIT_WINDOW_MS=60000

# Runner Images (customize for your registry)
RUNNER_IMAGE_JAVA=testcraft/runner-java:latest
RUNNER_IMAGE_PYTHON=testcraft/runner-python:latest
RUNNER_IMAGE_CSHARP=testcraft/runner-csharp:latest
RUNNER_IMAGE_JAVASCRIPT=testcraft/runner-javascript:latest
RUNNER_IMAGE_TYPESCRIPT=testcraft/runner-typescript:latest
RUNNER_IMAGE_GO=testcraft/runner-go:latest
RUNNER_IMAGE_RUST=testcraft/runner-rust:latest
RUNNER_IMAGE_RUBY=testcraft/runner-ruby:latest
RUNNER_IMAGE_PHP=testcraft/runner-php:latest
RUNNER_IMAGE_KOTLIN=testcraft/runner-kotlin:latest
