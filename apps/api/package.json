{
  "name": "@testcraft/api",
  "version": "1.0.0",
  "description": "TestCraft AI Backend API",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:rollback": "tsx src/scripts/migrate.ts rollback",
    "migrate:status": "tsx src/scripts/migrate.ts status"
  },
  "dependencies": {
    "@testcraft/shared-types": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "@kubernetes/client-node": "^0.21.0",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.1",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
