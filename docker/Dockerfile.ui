FROM node:20-alpine AS builder

WORKDIR /app

# Copy root package files
COPY package*.json ./

# Copy workspace packages
COPY apps/web/package*.json ./apps/web/
COPY packages/shared-types/package*.json ./packages/shared-types/

# Install dependencies from root
RUN npm install --workspace=@testcraft/web --include-workspace-root

# Copy source
COPY apps/web ./apps/web
COPY packages/shared-types ./packages/shared-types
COPY tsconfig.json .
COPY turbo.json .

# Build using turbo
RUN npm install -g turbo
RUN turbo run build --filter=@testcraft/web

# Production image
FROM nginx:alpine

# The build output goes to apps/web/dist or similar depending on angular.json
# Let's check angular.json to be sure of the path, but usually it's apps/web/dist
COPY --from=builder /app/apps/web/dist/*/browser /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
